MYSQLHOST=switchback.proxy.rlwy.net
MYSQLPORT=21956
MYSQLUSER=root
MYSQLPASSWORD=ErJDnYkJhYRtjKqDYcwQPLKfvbpNlIYP
MYSQLDATABASE=petsona

# Alternative: Use DATABASE_URI directly (overrides individual vars above)
# DATABASE_URI=mysql+pymysql://user:password@host:port/database

# ==============================================================================
# EMAIL / SMTP CONFIGURATION
# ==============================================================================
# Gmail with App Password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=jeysalas05@gmail.com
