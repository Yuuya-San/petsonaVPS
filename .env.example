# ========================
# REQUIRED - CORE CONFIG
# ========================
SECRET_KEY=your-very-secure-random-secret-key-here
DATABASE_URI=mysql+pymysql://username:password@localhost/petsona
FLASK_ENV=production

# ========================
# REQUIRED - EMAIL CONFIG
# ========================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@petsona.com

# ========================
# REQUIRED - GOOGLE OAUTH
# ========================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========================
# REQUIRED - ADMIN ACCOUNT
# ========================
ADMIN_PASSWORD=your-secure-admin-password

# ========================
# OPTIONAL - SECURITY
# ========================
MAX_FAILED_LOGIN=5
LOCKOUT_TIME=300
RESET_TOKEN_EXPIRY=3600

# ========================
# OPTIONAL - FRONTEND
# ========================
FRONTEND_URL=https://yourdomain.com

# ========================
# DEVELOPMENT ONLY
# ========================
# For local development, you can use simpler values
# For production, use strong, unique values
# 
# To generate a strong SECRET_KEY:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
