# ==============================================================================
# FLASK CONFIGURATION
# ==============================================================================
FLASK_APP=run.py
FLASK_ENV=production  # Set to 'development' for local development
SECRET_KEY=your-super-secret-key-change-this-in-production

# ==============================================================================
# RAILWAY MYSQL DATABASE CONFIGURATION
