# ==============================================================================
# GOOGLE OAUTH CONFIGURATION
# ==============================================================================
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=465984026247-mcqjo45k0dqcrsn9rmf1o9dp0vaqjbbn.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# ==============================================================================
# OAUTH SETTINGS
# ==============================================================================
# Set to False for production (requires HTTPS)
# Set to True only for local development with HTTP
AUTHLIB_INSECURE_TRANSPORT=False

# ==============================================================================
# SECURITY SETTINGS
# ==============================================================================
# Password reset token expiry in seconds (default: 3600 = 1 hour)
RESET_TOKEN_EXPIRY=3600

# Max failed login attempts before account lockout
MAX_FAILED_LOGIN=5

# Account lockout time in seconds (default: 300 = 5 minutes)
LOCKOUT_TIME=300

# ==============================================================================
# FRONTEND CONFIGURATION (Optional)
# ==============================================================================
# Use this if you have a separate frontend application
FRONTEND_URL=https://your-frontend-domain.com

# ==============================================================================
# LOCAL DEVELOPMENT FALLBACKS (Only used if Railway vars are missing in dev)
# ==============================================================================
# These are OPTIONAL and only used during local development
# For Railway production, the MYSQL* variables above are required
# Uncomment below only for local MySQL testing:
#
# MYSQLHOST=localhost
# MYSQLPORT=3306
# MYSQLUSER=root
# MYSQLPASSWORD=12345
